<?xml version="1.0"?>
<Xdmf>
    <Domain>
        <Grid Name="mesh">
            <Topology TopologyType="Polyline" NumberOfElements="384">
                <DataItem Dimensions="768" Format="HDF">test_burgers_3.h5:/mesh/connectivity</DataItem>
            </Topology>
            <Geometry GeometryType="XYZ">
                <DataItem Dimensions="1155" Format="HDF">test_burgers_3.h5:/mesh/points</DataItem>
            </Geometry>
            <Attribute Name="phi" Center="Cell">
                <DataItem Dimensions="384" Format="HDF" Precision="8">test_burgers_3.h5:/mesh/fields/phi</DataItem>
            </Attribute>
        </Grid>
    </Domain>
</Xdmf>
